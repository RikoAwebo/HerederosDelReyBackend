## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/

# .NET
*.dll
*.exe
*.pdb
*.cache
*.deps.json
*.runtimeconfig.json

# Rider / VS Code / VS
.vs/
.idea/
.vscode/

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# NuGet
*.nupkg
*.snupkg
packages/
.nuget/
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET / Web
wwwroot/dist/
wwwroot/node_modules/

# Node (if using frontend tooling)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Logs
*.log

# OS files
.DS_Store
Thumbs.db

# Test results
TestResults/
*.trx

# Coverage
coverage/
*.coverage
*.coveragexml

# Publish output
publish/

# Azure
*.azurePubxml

# Resharper
_ReSharper*/
*.DotSettings.user

# Dotnet local tools
.dotnet-tools.json

# Environment files
.env
.env.*

# Generated files
Generated/
